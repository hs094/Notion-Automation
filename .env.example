# Notion integration token — https://www.notion.so/profile/integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Data source UUIDs (a database is one or more data sources; copy from the URL or API)
NOTION_DATA_SOURCE_ID=00000000-0000-0000-0000-000000000000
NOTION_CHANNELS_DATA_SOURCE_ID=00000000-0000-0000-0000-000000000000

# Video source: "ytdlp" (default, works locally) or "youtube_api" (for CI/datacenter IPs)
# YT_SOURCE=ytdlp

# YouTube Data API key — required when YT_SOURCE=youtube_api
# https://console.cloud.google.com/apis/credentials
# YT_API_KEY=your_api_key_here
